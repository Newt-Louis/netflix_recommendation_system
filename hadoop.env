HADOOP_HOME=/opt/hadoop
HADOOP_CONF_DIR=/opt/hadoop/etc/hadoop
HADOOP_USER_NAME=root

# HDFS core configuration
CORE-SITE.XML_fs.defaultFS=hdfs://namenode:8020
CORE-SITE.XML_hadoop.tmp.dir=/hadoop/tmp

# HDFS single-datanode lab configuration
HDFS-SITE.XML_dfs.replication=1
HDFS-SITE.XML_dfs.permissions.enabled=false

HDFS-SITE.XML_dfs.namenode.rpc-address=namenode:8020
HDFS-SITE.XML_dfs.namenode.http-address=namenode:9870

HDFS-SITE.XML_dfs.namenode.name.dir=file:///hadoop/dfs/name
HDFS-SITE.XML_dfs.datanode.data.dir=file:///hadoop/dfs/data

HDFS-SITE.XML_dfs.datanode.address=0.0.0.0:9866
HDFS-SITE.XML_dfs.datanode.http.address=0.0.0.0:9864

HDFS-SITE.XML_dfs.webhdfs.enabled=true
HDFS-SITE.XML_dfs.client.use.datanode.hostname=true
HDFS-SITE.XML_dfs.datanode.use.datanode.hostname=true
HDFS-SITE.XML_dfs.datanode.hostname=datanode